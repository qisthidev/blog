---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

// Series highlights - group posts by series tags
const seriesTags = [
  {
    tag: "series-laravel-octane-mastery",
    title: "🚀 Laravel Octane Mastery",
    desc: "From zero to production with Swoole",
  },
  {
    tag: "series-supercharging-laravel-with-postgresql-query-optimization",
    title: "⚡ Laravel Optimization",
    desc: "Query tuning, indexing, and performance",
  },
  {
    tag: "series-from-laravel-to-go-writing-clean-craftsmanship-grade-code-in-golang",
    title: "🔄 From Laravel to Go",
    desc: "Clean code in a statically typed world",
  },
  {
    tag: "series-spring-boot-for-laravel-developers",
    title: "☕ Spring Boot for Laravel Devs",
    desc: "JVM ecosystem for PHP developers",
  },
  {
    tag: "series-deep-dive-into-laravel-database-indexing",
    title: "🔍 Deep Dive: Laravel Indexing",
    desc: "Database indexing strategies",
  },
  {
    tag: "series-kelas-pakar",
    title: "🎓 Kelas Pakar",
    desc: "Expert perspectives on diverse topics",
  },
];

// Topic clusters for SEO Hub & Spoke architecture
const topics = [
  { tag: "laravel", title: "Laravel", emoji: "🔥" },
  { tag: "php", title: "PHP", emoji: "🐘" },
  { tag: "postgresql", title: "PostgreSQL", emoji: "🐘" },
  { tag: "go", title: "Go", emoji: "🐹" },
  { tag: "java", title: "Java & Spring", emoji: "☕" },
  { tag: "devops-and-infrastructure", title: "DevOps", emoji: "⚙️" },
  { tag: "productivity", title: "Productivity", emoji: "💡" },
];
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Hey, I'm Rama 👋
      </h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="inline-block"
        aria-label="RSS feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <p>
        I'm a full-stack developer from Indonesia, writing about Laravel, PHP,
        Go, PostgreSQL, DevOps, and modern web development. I share deep-dive
        tutorials, performance optimization case studies, and practical guides
        to help you write cleaner, faster code.
      </p>
      {
        SOCIALS.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Find me on:</div>
            <Socials />
          </div>
        )
      }
    </section>

    <section
      id="series"
      class:list={["pt-12 pb-6", "border-b border-border"]}
    >
      <h2 class="text-2xl font-semibold tracking-wide">📚 Series</h2>
      <p class="mt-2 mb-4 text-sm opacity-80">
        In-depth, multi-part tutorials covering topics from start to finish.
      </p>
      <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        {
          seriesTags.map(series => (
            <li>
              <a
                href={`/tags/${series.tag}/`}
                class="group flex flex-col rounded-lg border border-border p-4 transition-all hover:border-accent/50 hover:bg-accent/5"
              >
                <span class="font-semibold group-hover:text-accent">
                  {series.title}
                </span>
                <span class="text-sm opacity-70">{series.desc}</span>
              </a>
            </li>
          ))
        }
      </ul>
    <section
      id="topics"
      class:list={["pt-12 pb-6", "border-b border-border"]}
    >
      <h2 class="text-2xl font-semibold tracking-wide">🏷️ Topics</h2>
      <p class="mt-2 mb-4 text-sm opacity-80">
        Explore articles by core technology and subject areas.
      </p>
      <div class="flex flex-wrap gap-3">
        {
          topics.map(topic => (
            <a
              href={`/tags/${topic.tag}/`}
              class="group flex items-center gap-2 rounded-full border border-border px-4 py-2 text-sm transition-all hover:border-accent hover:bg-accent/5 hover:text-accent font-medium"
            >
              <span>{topic.emoji}</span>
              <span>{topic.title}</span>
            </a>
          ))
        }
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/blog/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
