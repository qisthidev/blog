---
interface Props {
  llmMdUrl: string;
}

const { llmMdUrl } = Astro.props;
---

<div class="flex flex-none flex-col items-center justify-center gap-1">
  <span class="italic">LLM-friendly version:</span>
  <div class="flex flex-wrap items-center justify-center gap-2 text-sm text-center">
    <button
      id="llm-copy-md"
      data-llm-url={llmMdUrl}
      class="inline-flex cursor-pointer items-center gap-1.5 rounded-md border border-border/50 bg-muted/30 px-3 py-1.5 font-medium text-foreground/80 transition-all duration-200 hover:border-accent/40 hover:bg-accent/10 hover:text-accent"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
      <span>Copy Markdown</span>
    </button>

    <button
      id="llm-copy-link"
      data-llm-url={llmMdUrl}
      class="inline-flex cursor-pointer items-center gap-1.5 rounded-md border border-border/50 bg-muted/30 px-3 py-1.5 font-medium text-foreground/80 transition-all duration-200 hover:border-accent/40 hover:bg-accent/10 hover:text-accent"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      <span>Copy Markdown Link</span>
    </button>

    <a
      href={`https://chatgpt.com/?hints=search&q=${encodeURIComponent(`Read ${llmMdUrl} and summarize`)}`}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 rounded-md border border-border/50 bg-muted/30 px-3 py-1.5 font-medium text-foreground/80 no-underline transition-all duration-200 hover:border-[#10a37f]/40 hover:bg-[#10a37f]/10 hover:text-[#10a37f]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.998 5.998 0 0 0-3.998 2.9 6.042 6.042 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"/></svg>
      <span>Open in ChatGPT</span>
    </a>

    <a
      href={`https://claude.ai/new?q=${encodeURIComponent(`Read ${llmMdUrl} and summarize`)}`}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 rounded-md border border-border/50 bg-muted/30 px-3 py-1.5 font-medium text-foreground/80 no-underline transition-all duration-200 hover:border-[#d97706]/40 hover:bg-[#d97706]/10 hover:text-[#d97706]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M4.709 15.955l4.486-2.236a.39.39 0 0 0 .168-.528.39.39 0 0 0-.527-.168l-4.486 2.236a.39.39 0 0 0-.168.528.39.39 0 0 0 .527.168m8.907-7.677l-1.283.639a.39.39 0 0 0-.168.528.39.39 0 0 0 .528.168l1.282-.64a.39.39 0 0 0 .168-.527.39.39 0 0 0-.527-.168m-3.97 4.346L5.794 14.66a.39.39 0 0 0-.168.528.39.39 0 0 0 .527.168l3.852-1.918a.39.39 0 0 0 .168-.528.39.39 0 0 0-.528-.168m6.19-4.724l-2.344 1.166a.39.39 0 0 0-.168.528.39.39 0 0 0 .527.168l2.345-1.167a.39.39 0 0 0 .168-.528.39.39 0 0 0-.528-.168m2.834-.638a.39.39 0 0 0-.168-.528L12.12 3.252a.78.78 0 0 0-.694 0L4.86 6.77a.78.78 0 0 0-.41.69v7.098a.78.78 0 0 0 .41.69l6.565 3.518a.78.78 0 0 0 .694 0l6.566-3.518a.78.78 0 0 0 .41-.69V7.46a.39.39 0 0 0-.168-.528.39.39 0 0 0-.527.168v6.96l-6.262 3.354V10.56l6.933-3.454a.39.39 0 0 0 .168-.528M11.358 17.42l-6.128-3.282V7.753l6.128 3.282z"/></svg>
      <span>Open in Claude</span>
    </a>
  </div>
</div>

<script is:inline data-astro-rerun>
  function initLlmActions() {
    const copyMdBtn = document.getElementById("llm-copy-md");
    const copyLinkBtn = document.getElementById("llm-copy-link");

    if (copyMdBtn) {
      copyMdBtn.addEventListener("click", async () => {
        const url = copyMdBtn.getAttribute("data-llm-url");
        if (!url) return;
        try {
          const res = await fetch(url);
          const text = await res.text();
          await navigator.clipboard.writeText(text);
          const span = copyMdBtn.querySelector("span");
          if (span) {
            const original = span.textContent;
            span.textContent = "Copied!";
            setTimeout(() => { span.textContent = original; }, 1500);
          }
        } catch (err) {
          console.error("Failed to copy markdown:", err);
        }
      });
    }

    if (copyLinkBtn) {
      copyLinkBtn.addEventListener("click", async () => {
        const url = copyLinkBtn.getAttribute("data-llm-url");
        if (!url) return;
        try {
          await navigator.clipboard.writeText(url);
          const span = copyLinkBtn.querySelector("span");
          if (span) {
            const original = span.textContent;
            span.textContent = "Copied!";
            setTimeout(() => { span.textContent = original; }, 1500);
          }
        } catch (err) {
          console.error("Failed to copy link:", err);
        }
      });
    }
  }
  initLlmActions();
</script>
